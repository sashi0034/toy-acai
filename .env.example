# Slack upload settings for local-scripts/slack-uploader.sh.
# Copy this to .env and fill in the real values on the login node.
# Required Slack bot OAuth scopes: files:write, chat:write
# Invite the bot user to SLACK_CHANNEL_ID before uploading files.
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_CHANNEL_ID=C0123456789

# Optional local defaults.
TOY_ACAI_SLACK_SPOOL=outputs/rl/default/slack
TOY_ACAI_OUTPUT_DIR=outputs/rl/default

TOY_ACAI_EPISODES=200
TOY_ACAI_STEPS=1200
TOY_ACAI_RENDER_EVERY=10

TOY_ACAI_RANDOM_START_STEPS=120
TOY_ACAI_ROLLOUT_STEPS=512
TOY_ACAI_BATCH_SIZE=128
